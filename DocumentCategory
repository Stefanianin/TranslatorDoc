import SwiftUI

enum DocumentCategory: String, CaseIterable, Identifiable {
    case importante
    case deServiciu
    case contracte
    case ghiduri
    case formulare

    var id: String { rawValue }

    var label: String {
        switch self {
        case .importante: return "Importante"
        case .deServiciu: return "De serviciu"
        case .contracte: return "Contracte"
        case .ghiduri: return "Ghiduri"
        case .formulare: return "Formulare"
        }
    }

    var subtitle: String {
        switch self {
        case .importante: return "Certificări, acte, documente esențiale"
        case .deServiciu: return "Politici, tarife, proceduri interne"
        case .contracte: return "Modele și contracte semnate"
        case .ghiduri: return "Terminologie, stil, standarde"
        case .formulare: return "Cereri, declarații, fișe"
        }
    }

    var color: Color {
        switch self {
        case .importante: return Color(red: 0.78, green: 0.16, blue: 0.16)
        case .deServiciu: return Color(red: 0.08, green: 0.40, blue: 0.75)
        case .contracte: return Color(red: 0.18, green: 0.49, blue: 0.20)
        case .ghiduri: return Color(red: 0.42, green: 0.11, blue: 0.60)
        case .formulare: return Color(red: 0.90, green: 0.32, blue: 0.0)
        }
    }

    var icon: String {
        switch self {
        case .importante: return "star.fill"
        case .deServiciu: return "briefcase.fill"
        case .contracte: return "doc.text.fill"
        case .ghiduri: return "book.fill"
        case .formulare: return "doc.on.doc.fill"
        }
    }
}
