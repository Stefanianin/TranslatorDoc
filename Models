import Foundation

struct Document: Identifiable, Hashable {
    let id: String
    let title: String
    let description: String
    let language: TranslatorLanguage
    let category: DocumentCategory
    let fileName: String
    /// Link PDF extern (opțional). Textul model e în `document-templates.json`.
    let url: URL

    var templateText: String {
        DocumentTemplateStore.text(for: id)
    }
}
